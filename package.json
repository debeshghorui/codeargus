{
    "name": "codeargus",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "db:migrate": "bun --bun run prisma migrate dev",
        "db:generate": "bun --bun run prisma generate",
        "db:studio": "bun --bun run prisma studio",
        "db:seed": "ts-node prisma/seed.ts",
        "db:reset": "bun --bun run prisma migrate reset --force --skip-seed",
        "db:push": "bun --bun run prisma db push",
        "db:pull": "bun --bun run prisma db pull",
        "db:diff": "bun --bun run prisma diff",
        "db:deploy": "bun --bun run prisma migrate deploy",
        "db:status": "bun --bun run prisma migrate status",
        "db:generate:watch": "bun --bun run prisma generate --watch",
        "db:migrate:watch": "bun --bun run prisma migrate dev --watch"
    },
    "packageManager": "bun",
    "dependencies": {
        "@base-ui/react": "^1.5.0",
        "@hugeicons/core-free-icons": "^4.2.0",
        "@hugeicons/react": "^1.1.7",
        "@prisma/adapter-pg": "^7.8.0",
        "@prisma/client": "^7.8.0",
        "@tanstack/react-query": "^5.101.0",
        "@types/pg": "^8.20.0",
        "better-auth": "^1.6.19",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.4.0",
        "dotenv": "^17.4.2",
        "embla-carousel-react": "^8.6.0",
        "inngest": "^4.11.0",
        "input-otp": "^1.4.2",
        "next": "16.2.9",
        "next-themes": "^0.4.6",
        "octokit": "^5.0.5",
        "pg": "^8.21.0",
        "prisma": "^7.8.0",
        "radix-ui": "^1.6.0",
        "react": "19.2.4",
        "react-day-picker": "^10.0.1",
        "react-dom": "19.2.4",
        "react-resizable-panels": "^4.11.2",
        "recharts": "3.8.0",
        "shadcn": "^4.11.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "vaul": "^1.1.2"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "eslint": "^9",
        "eslint-config-next": "16.2.9",
        "eslint-config-prettier": "^10.1.8",
        "prettier": "^3.8.4",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "tailwindcss": "^4",
        "typescript": "^5"
    },
    "ignoreScripts": [
        "sharp",
        "unrs-resolver"
    ],
    "trustedDependencies": [
        "sharp",
        "unrs-resolver"
    ]
}
